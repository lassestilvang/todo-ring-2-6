# Environment Variables Template
# Copy this file to .env.local and fill in your values
# IMPORTANT: Never commit .env.local to version control
# Never use these exact values in production - generate your own secrets

# Database
DATABASE_URL=./db.sqlite

# Authentication
# Generate strong secrets: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-here
AUTH_SECRET=your-auth-secret-here

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Push Notification Keys (VAPID)
# Generate with: web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:your-contact@domain.com

# OpenAI API Keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Monitoring
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Optional: Redis for caching (if used)
# REDIS_URL=redis://localhost:6379

# Security Headers configuration
# Security Headers: Configure based on your deployment needs
# These are examples - adjust for your environment
SECURITY_HEADERS_ENABLED=true
CONTENT_SECURITY_POLICY="default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https:;"
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
REFERRER_POLICY=strict-origin-when-cross-origin
PERMISSIONS_POLICY="geolocation=(), microphone=(), camera=(), fullscreen=(self)"
STRICT_TRANSPORT_SECURITY="max-age=31536000; includeSubDomains"

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: Feature Flags
FEATURE_AI_TASK_PRIORITIZATION=true
FEATURE_OFFLINE_SYNC=true
FEATURE_REAL_TIME_COLLABORATION=true