{
  "name": "taskplanner",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "db:init": "node --experimental-strip-types scripts/init-db.mjs",
    "db:reset": "rm -f db.sqlite && node --experimental-strip-types scripts/init-db.mjs",
    "load-test": "node scripts/load-test.js",
    "ws": "node scripts/start-ws-server.js",
    "recurring": "node scripts/process-recurring.js",
    "notification:process": "tsx scripts/notification-scheduler.ts",
    "notification:test": "tsx scripts/test-notifications.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run ws\"",
    "deploy": "echo 'Add deployment steps'"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@radix-ui/react-checkbox": "1.3.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.18",
    "@radix-ui/react-popover": "1.1.17",
    "@radix-ui/react-select": "2.3.1",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "better-sqlite3": "12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "cmdk": "^1.0.0",
    "date-fns": "^4.0.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "next": "^16.0.0",
    "next-themes": "0.4.6",
    "nodemailer": "^9.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "xss": "^1.0.15",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/bun": "^1.2.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "4.1.9",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "tailwindcss": "3.4.19",
    "typescript": "^5.6.0",
    "vitest": "4.1.9"
  }
}
