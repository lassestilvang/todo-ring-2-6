{
  "name": "taskplanner",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "benchmark": "tsx scripts/benchmark.ts",
    "benchmark:api": "tsx scripts/benchmark-api.ts",
    "docs": "swagger-ui-express ./openapi.yaml",
    "docs:generate": "tsx scripts/generate-api-docs.ts",
    "storybook": "storybook dev",
    "storybook:build": "storybook build",
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:integration": "vitest run -c vitest.config.node.ts",
    "test:node": "vitest run -c vitest.config.node.ts",
    "test:integration:watch": "vitest -c vitest.config.node.ts",
    "db:init": "node --experimental-strip-types scripts/init-db.mjs",
    "db:reset": "rm -f db.sqlite && node --experimental-strip-types scripts/init-db.mjs",
    "load-test": "node scripts/load-test.js",
    "ws": "node scripts/start-ws-server.js",
    "recurring": "node scripts/process-recurring.js",
    "notification:process": "tsx scripts/notification-scheduler.ts",
    "notification:test": "tsx scripts/test-notifications.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run ws\"",
    "analyze": "ANALYZE=true next build",
    "deploy": "echo 'Add deployment steps'",
    "backup": "tsx scripts/backup-db.ts",
    "setup-backup-cron": "tsx scripts/setup-backup-cron.ts",
    "generate-docs": "tsx scripts/generate-api-docs.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@radix-ui/react-checkbox": "1.3.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.18",
    "@radix-ui/react-popover": "1.1.17",
    "@radix-ui/react-select": "2.3.1",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-tooltip": "1.2.10",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "@tanstack/react-virtual": "3.14.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.0.0",
    "cmdk": "^1.0.0",
    "date-fns": "^4.0.0",
    "framer-motion": "^11.0.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.400.0",
    "next": "15.3.5",
    "next-themes": "0.4.6",
    "nodemailer": "^9.0.0",
    "puppeteer": "25.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-window": "2.2.7",
    "recharts": "3.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "3.4.19",
    "unleash-client": "^4.3.0",
    "web-push": "^3.6.7",
    "winston": "^3.13.0",
    "redis": "^4.6.0",
    "bullmq": "^4.0.0",
    "winston-papertrail": "^2.3.0",
    "winston-transport": "^4.6.0",
    "ws": "^8.21.0",
    "xss": "^1.0.15",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@axe-core/playwright": "^4.11.3",
    "@axe-core/react": "^4.11.3",
    "@hookform/resolvers": "5.4.0",
    "@next/bundle-analyzer": "16.2.9",
    "@radix-ui/react-progress": "1.1.10",
    "@radix-ui/react-slider": "1.4.1",
    "@radix-ui/react-switch": "1.3.1",
    "@sentry/nextjs": "^10.59.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/bun": "^1.2.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/puppeteer": "5.4.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-window": "1.8.8",
    "@types/recharts": "1.8.29",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-istanbul": "^4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.12.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "react-hook-form": "7.80.0",
    "typescript": "^5.6.0",
    "vitest": "4.1.9",
    "vitest-axe": "^0.1.0",
    "webpack-bundle-analyzer": "^5.3.0"
  }
}
