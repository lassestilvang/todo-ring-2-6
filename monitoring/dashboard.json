{
  "dashboard": {
    "id": null,
    "title": "TaskPlanner Monitoring",
    "tags": ["task-planner", "application-monitoring"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "type": "graph",
        "title": "HTTP Request Rate",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(http_requests_total{job=\"taskplanner\"}[5m])",
            "legendFormat": "{{method}} - {{status}}"
          }
        ]
      },
      {
        "id": 2,
        "type": "graph",
        "title": "Response Time Percentiles",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"taskplanner\"}[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"taskplanner\"}[5m]))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Database Connection Pool",
        "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
        "targets": [
          {
            "expr": "db_connection_pool_usage{job=\"taskplanner\"}",
            "legendFormat": "Connections Used"
          }
        ]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Active WebSocket Connections",
        "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6},
        "targets": [
          {
            "expr": "ws_active_connections{job=\"taskplanner\"}",
            "legendFormat": "Active Connections"
          }
        ]
      },
      {
        "id": 5,
        "type": "graph",
        "title": "Background Jobs Queue",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "bullmq_jobs_in_queue{job=\"taskplanner\"}",
            "legendFormat": "{{queue}} - {{status}}"
          }
        ]
      },
      {
        "id": 6,
        "type": "table",
        "title": "API Error Rates",
        "gridPos": {"x": 0, "y": 14, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(api_errors_total{job=\"taskplanner\"}[15m])",
            "legendFormat": "{{endpoint}} - {{error_type}}"
          }
        ]
      },
      {
        "id": 7,
        "type": "heatmap",
        "title": "Task Creation Heatmap",
        "gridPos": {"x": 12, "y": 14, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(tasks_created_total{job=\"taskplanner\"}[1h])",
            "legendFormat": "Tasks/Hour"
          }
        ]
      }
    ]
  }
}